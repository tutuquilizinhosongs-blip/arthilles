# ArthillesBot - MVP Gratuito - Copie este arquivo para backend/.env

NODE_ENV=production
LOG_LEVEL=info

# URLs (preencha depois do deploy)
BACKEND_PUBLIC_URL=https://seu-backend.up.railway.app
DASHBOARD_PUBLIC_URL=https://seu-dashboard.vercel.app
CORS_ORIGIN=https://seu-dashboard.vercel.app,https://*.vercel.app

# Login do Admin (use isso para entrar no painel)
AUTH_SECRET=coloque_um_segredo_qualquer_aqui
ADMIN_EMAIL=admin@seudominio.com
ADMIN_PASSWORD=sua_senha_forte_aqui

# Supabase (obrigatório)
SUPABASE_URL=https://seu-projeto.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Google Sheets FAQ (principal funcionalidade gratuita)
GOOGLE_SHEETS_CSV_URL=https://docs.google.com/spreadsheets/d/SEU_ID/export?format=csv

# Evolution API (WhatsApp)
# Recomendado: configure pelo painel (aba WhatsApp) depois do deploy.
# Estas variáveis servem como fallback caso nada esteja salvo no banco.
EVOLUTION_API_URL=https://sua-evolution-api.com
EVOLUTION_API_KEY=sua_chave
EVOLUTION_INSTANCE_NAME=arthilles-demo
